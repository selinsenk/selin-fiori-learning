<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="high-level-architecture" name="High-Level Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Tax Rates x Balance Sheet — High-Level Architecture" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1520" height="40" as="geometry" />
        </mxCell>

        <!-- ============ LEFT SIDE : RUNNING CAP APP ============ -->
        <mxCell id="capGroup" value="Runs on your laptop — CAP / Node.js  (localhost:4004)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=14;fillColor=#F5F5F5;strokeColor=#666666;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="620" height="920" as="geometry" />
        </mxCell>

        <!-- SAPUI5 CDN -->
        <mxCell id="cdn" value="SAPUI5 Runtime 1.148.5&#10;(https://ui5.sap.com)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="120" y="110" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Browser box -->
        <mxCell id="browser" value="Browser — app/taxbalance/webapp&#10;index.html -&gt; Component.js -&gt; manifest.json&#10;&#10;Fiori Elements floorplans:&#10;ListReport (Screen 1)  +  ObjectPage (Screen 2, tabs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;fontSize=12;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="180" width="540" height="120" as="geometry" />
        </mxCell>

        <!-- srv layer -->
        <mxCell id="srv" value="srv/ — OData V4 Service  (/odata/v4/tax-balance)&#10;&#10;tax-service.cds   — exposed entities, @odata.draft.enabled, Capabilities&#10;annotations.cds   — the entire UI, as metadata (UI.LineItem, Facets, ValueList...)&#10;tax-service.js    — calculatedAmount handler + draft-aware reads" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;fontSize=12;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="380" width="540" height="130" as="geometry" />
        </mxCell>

        <!-- db layer -->
        <mxCell id="db" value="db/ — Data Model&#10;&#10;schema.cds  — CompanyLayers (root) -&gt; TaxRates (composition),&#10;GLAccounts (association), CompanyCodes, Layers, Countries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;fontSize=12;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="590" width="540" height="100" as="geometry" />
        </mxCell>

        <!-- SQLite -->
        <mxCell id="sqlite" value="SQLite (in-memory)&#10;reseeded from db/data/*.csv on every start" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
