<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="cds-entities" name="CDS Entity Model">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="db/schema.cds — Entity Model (associations &amp; compositions)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="0" y="10" width="1400" height="36" as="geometry" />
        </mxCell>

        <!-- ================= MASTER DATA (code lists) ================= -->

        <mxCell id="countries" value="&lt;div style=&quot;font-weight:bold;font-size:13px;&quot;&gt;Countries&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-style:italic;color:#555555;&quot;&gt;«master data / code list» — cf. T005&lt;/div&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;div style=&quot;text-align:left;font-size:12px;&quot;&gt;&lt;u&gt;PK code&lt;/u&gt; : String(3)&lt;br/&gt;name : String(60)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="70" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="companyCodes" value="&lt;div style=&quot;font-weight:bold;font-size:13px;&quot;&gt;CompanyCodes&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-style:italic;color:#555555;&quot;&gt;«master data / code list» — cf. T001&lt;/div&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;div style=&quot;text-align:left;font-size:12px;&quot;&gt;&lt;u&gt;PK code&lt;/u&gt; : String(4)&lt;br/&gt;name : String(60)&lt;br/&gt;countryCode : String(3)&lt;br/&gt;&lt;i&gt;country&lt;/i&gt; → assoc to one Countries&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="260" y="260" width="260" height="130" as="geometry" />
        </mxCell>

        <mxCell id="layers" value="&lt;div style=&quot;font-weight:bold;font-size:13px;&quot;&gt;Layers&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-style:italic;color:#555555;&quot;&gt;«master data / code list»&lt;/div&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;div style=&quot;text-align:left;font-size:12px;&quot;&gt;&lt;u&gt;PK ID&lt;/u&gt; : String(2)&lt;br/&gt;description : String(60)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="260" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- ================= ROOT ENTITY ================= -->

        <mxCell id="companyLayers" value="&lt;div style=&quot;font-weight:bold;font-size:14px;&quot;&gt;CompanyLayers&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-style:italic;color:#555555;&quot;&gt;«root entity» — draft-enabled (@odata.draft.enabled)&lt;/div&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;div style=&quot;text-align:left;font-size:12px;&quot;&gt;&lt;u&gt;PK companyCode&lt;/u&gt; : String(4)&lt;br/&gt;&lt;u&gt;PK layerID&lt;/u&gt; : String(2)&lt;br/&gt;&lt;i&gt;company&lt;/i&gt; → assoc to one CompanyCodes&lt;br/&gt;&lt;i&gt;layer&lt;/i&gt; → assoc to one Layers&lt;br/&gt;&lt;i&gt;taxRates&lt;/i&gt; → composition of many TaxRates&lt;br/&gt;&lt;i&gt;glAccounts&lt;/i&gt; → assoc to many GLAccounts&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=top;spacing=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="450" width="320" height="180" as="geometry" />
        </mxCell>

        <!-- ================= COMPOSITION CHILD ================= -->

        <mxCell id="taxRates" value="&lt;div style=&quot;font-weight:bold;font-size:13px;&quot;&gt;TaxRates&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-style:italic;color:#555555;&quot;&gt;«composition child» — owned by CompanyLayers&lt;/div&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;div style=&quot;text-align:left;font-size:12px;&quot;&gt;&lt;u&gt;PK ID&lt;/u&gt; : UUID&lt;br/&gt;&lt;i&gt;parent&lt;/i&gt; → assoc to one CompanyLayers (managed)&lt;br/&gt;rateType : String(40)&lt;br/&gt;rateValue : Decimal(5,2)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=top;spacing=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="740" width="280" height="140" as="geometry" />
        </mxCell>

        <!-- ================= RELATED, NOT OWNED ================= -->

        <mxCell id="glAccounts" value="&lt;div style=&quot;font-weight:bold;font-size:13px;&quot;&gt;GLAccounts&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-style:italic;color:#555555;&quot;&gt;«related, NOT owned» — read-only, independent master/transactional data&lt;/div&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;div style=&quot;text-align:left;font-size:12px;&quot;&gt;&lt;u&gt;PK companyCode&lt;/u&gt; : String(4)&lt;br/&gt;&lt;u&gt;PK layerID&lt;/u&gt; : String(2)&lt;br/&gt;&lt;u&gt;PK accountNumber&lt;/u&gt; : String(10)&lt;br/&gt;accountName : String(60)&lt;br/&gt;balanceAmount : Decimal(15,2) [ISOCurrency]&lt;br/&gt;currency : String(3)&lt;br/&gt;virtual calculatedAmount : Decimal(15,2)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=top;spacing=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="440" width="320" height="200" as="geometry" />
        </mxCell>

        <!-- ================= EDGES ================= -->

        <!-- CompanyCodes -> Countries : association -->
        <mxCell id="e_cc_country" value="country&#10;0..1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;startArrow=none;fontSize=11;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.3;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="companyCodes" target="countries">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CompanyLayers -> CompanyCodes : association -->
        <mxCell id="e_cl_cc" value="company&#10;0..1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;startArrow=none;fontSize=11;exitX=0;exitY=0.3;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="companyLayers" target="companyCodes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CompanyLayers -> Layers : association -->
        <mxCell id="e_cl_layer" value="layer&#10;0..1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;startArrow=none;fontSize=11;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="companyLayers" target="layers">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CompanyLayers to TaxRates : composition (owns) -->
        <mxCell id="e_cl_tr" value="taxRates&#10;0..*  (owns)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=diamondThin;startFill=1;endArrow=none;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="companyLayers" target="taxRates">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- TaxRates -> CompanyLayers : managed backlink association -->
        <mxCell id="e_tr_parent" value="parent (backlink, managed)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;startArrow=none;dashed=1;fontSize=10;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="taxRates" target="companyLayers">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CompanyLayers -> GLAccounts : association, key match, not owned -->
        <mxCell id="e_cl_gl" value="glAccounts  0..*&#10;(on companyCode/layerID match — NOT owned)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;startArrow=none;dashed=1;fontSize=11;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" edge="1" parent="1" source="companyLayers" target="glAccounts">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================= LEGEND ================= -->

        <mxCell id="legendBox" value="Legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;verticalAlign=top;fontStyle=1;fontSize=13;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="440" height="270" as="geometry" />
        </mxCell>

        <mxCell id="leg_master" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="60" y="475" width="24" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg_master_lbl" value="Master data / code list (used for value-help dropdowns)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="94" y="470" width="380" height="26" as="geometry" />
        </mxCell>

        <mxCell id="leg_root" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="60" y="510" width="24" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg_root_lbl" value="Root / transactional entity (what the user selects &amp; edits)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="94" y="505" width="380" height="26" as="geometry" />
        </mxCell>

        <mxCell id="leg_child" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1">
          <mxGeometry x="60" y="545" width="24" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg_child_lbl" value="Composition child (owned, cascades with parent/draft)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="94" y="540" width="380" height="26" as="geometry" />
        </mxCell>

        <mxCell id="leg_related" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="580" width="24" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg_related_lbl" value="Related, independent entity (referenced, not owned)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="94" y="575" width="380" height="26" as="geometry" />
        </mxCell>

        <mxCell id="leg_assoc_line" style="edgeStyle=none;html=1;endArrow=open;endFill=0;startArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="60" y="625" as="sourcePoint" />
            <mxPoint x="84" y="625" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_assoc_lbl" value="Association — &quot;I know about you&quot; (a reference / join)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="94" y="613" width="380" height="26" as="geometry" />
        </mxCell>

        <mxCell id="leg_comp_line" style="edgeStyle=none;html=1;startArrow=diamondThin;startFill=1;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="60" y="660" as="sourcePoint" />
            <mxPoint x="84" y="660" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_comp_lbl" value="Composition — &quot;I OWN you&quot; (cascading delete, drafted together)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="94" y="648" width="380" height="26" as="geometry" />
        </mxCell>

        <mxCell id="leg_dashed_line" style="edgeStyle=none;html=1;endArrow=open;endFill=0;startArrow=none;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="60" y="695" as="sourcePoint" />
            <mxPoint x="84" y="695" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_dashed_lbl" value="Dashed = managed/unmanaged assoc. without explicit FK column" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="94" y="683" width="380" height="26" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
